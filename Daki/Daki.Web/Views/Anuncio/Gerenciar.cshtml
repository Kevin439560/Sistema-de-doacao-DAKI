@model Daki.Dominio.Entidades.Anuncio

@{
    ViewData["Title"] = $"Gerenciar: {Model.Titulo}";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a href="/Anuncio/MeusAnuncios" class="text-decoration-none text-muted small mb-2 d-inline-block">
                <i class="bi bi-arrow-left"></i> Voltar para Meus Anúncios
            </a>
            <h2 class="fw-bold text-dark mb-0">Gerenciar Doação</h2>
        </div>

        <div>
            @if (Model.Status == Daki.Dominio.Enums.Status.Ativo)
            {
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 fs-6">Ativo e Visível</span>
            }
            else
            {
                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2 fs-6">@Model.Status</span>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-lg">
                @{
                    var imagemCapa = Model.Imagens?.FirstOrDefault(i => i.Principal)?.UrlImagem
                                     ?? "https://placehold.co/600x400/f8f9fa/ff7f50?text=Sem+Foto";
                }
                <img src="@imagemCapa" class="card-img-top" alt="Capa do anúncio" style="height: 200px; object-fit: cover;">

                <div class="card-body p-4">
                    <span class="badge bg-light text-secondary border mb-2">@Model.Categoria</span>
                    <h5 class="fw-bold text-dark">@Model.Titulo</h5>
                    <p class="text-muted small mb-4">Publicado em @Model.DataCriacao.ToString("dd/MM/yyyy 'às' HH:mm")</p>
                    <div class="d-flex gap-2 mt-3 mt-md-0">
                        <a href="/Anuncio/Editar/@Model.Id" class="btn btn-outline-primary">
                            <i class="bi bi-pencil-square me-1"></i> Editar Dados
                        </a>

                        @if (Model.Status == Daki.Dominio.Enums.Status.Ativo)
                        {
                            <a href="/Anuncio/Fechar/@Model.Id" class="btn btn-outline-danger" onclick="return confirm('Deseja realmente pausar este anúncio? Ninguém mais poderá pedir esta doação.');">
                                <i class="bi bi-pause-circle me-1"></i> Pausar / Ocultar
                            </a>
                        }
                        else if (Model.Status == Daki.Dominio.Enums.Status.Fechado)
                        {
                            <a href="/Anuncio/Reativar/@Model.Id" class="btn btn-success text-white">
                                <i class="bi bi-play-circle me-1"></i> Reativar Anúncio
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-lg h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold" style="color: #FF7F50;">
                        <i class="bi bi-people-fill me-2"></i> Pessoas Interessadas
                    </h5>
                    <p class="text-muted small">Leia as justificativas e escolha quem receberá a doação.</p>
                </div>
                <div class="card-body p-4 pt-2">

                    @if (Model.Interesses == null || !Model.Interesses.Any())
                    {
                        <div class="text-center py-5 bg-light rounded">
                            <i class="bi bi-envelope-open text-muted" style="font-size: 2.5rem;"></i>
                            <p class="mt-3 mb-0 text-secondary">Ainda não há nenhum pedido para este item.</p>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var interesse in Model.Interesses)
                            {
                                <div class="p-4 bg-white border rounded shadow-sm">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h6 class="fw-bold text-dark mb-1">
                                                <i class="bi bi-person-circle text-muted me-2"></i>@interesse.Usuario?.Nome
                                            </h6>
                                            <small class="text-muted">
                                                <i class="bi bi-calendar3 me-1"></i> Solicitado recentemente
                                            </small>
                                        </div>

                                        <div>
                                            @if (interesse.Status == Daki.Dominio.Enums.StatusInteresse.Pendente)
                                            {
                                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-3 py-1.5">Aguardando Resposta</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-secondary border px-3 py-1.5">@interesse.Status</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="p-3 bg-light rounded border-start border-3 border-secondary mb-3">
                                        <p class="mb-0 text-dark lh-base" style="white-space: pre-line; font-style: italic;">
                                            "@interesse.Justificativa"
                                        </p>
                                    </div>

                                    <div class="d-flex justify-content-end gap-2 pt-3 border-top mt-3">

                                        @if (Model.Status == Daki.Dominio.Enums.Status.Ativo && interesse.Status == Daki.Dominio.Enums.StatusInteresse.Pendente)
                                        {
                                            <a href="/Interesse/Recusar/@interesse.Id" class="btn btn-sm btn-outline-danger px-3"
                                               onclick="return confirm('Tem certeza que deseja RECUSAR este pedido? Esta ação não pode ser desfeita e a pessoa será avisada.');">
                                                <i class="bi bi-x-lg me-1"></i> Recusar
                                            </a>
                                            <a href="/Interesse/Aceitar/@interesse.Id" class="btn btn-sm text-white px-3" style="background-color: #FF7F50;" 
                                                onclick="return confirm('Tem certeza que deseja ESCOLHER esta pessoa? O item ficará reservado para ela e os outros pedidos ficarão aguardando.');">
                                                <i class="bi bi-check-lg me-1"></i>Aceitar
                                            </a>
                                        }
                                        else if (interesse.Status == Daki.Dominio.Enums.StatusInteresse.Aceita)
                                        {
                                            <div class="alert alert-success py-3 px-3 mb-0 w-100 border-0 shadow-sm">
                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                    <span><i class="bi bi-star-fill me-2 text-success"></i> <strong>Beneficiário Escolhido</strong></span>
                                                    <span class="text-dark"><i class="bi bi-telephone-fill me-1"></i> @interesse.Usuario?.Fone</span>
                                                </div>

                                                @{
                                                    var telefoneNumerico = new string((interesse.Usuario?.Fone ?? "").Where(char.IsDigit).ToArray());
                                                    var mensagemZap = $"Olá, {interesse.Usuario?.Nome}! Sou o doador do item '{Model.Titulo}' no Daki. Vamos combinar a entrega?";
                                                }

                                                <div class="d-flex flex-column gap-2">
                                                    <a href="https://api.whatsapp.com/send?phone=55@(telefoneNumerico)&text=@Uri.EscapeDataString(mensagemZap)" target="_blank" class="btn text-white w-100 fw-bold shadow-sm" style="background-color: #25D366;">
                                                        <i class="bi bi-whatsapp me-2"></i> Chamar no WhatsApp
                                                    </a>

                                                    <div class="d-flex gap-2 mt-1">
                                                        <a href="/Anuncio/CancelarReserva/@Model.Id" class="btn btn-sm btn-outline-danger w-50"
                                                           onclick="return confirm('Tem certeza que deseja CANCELAR esta reserva? O anúncio voltará a ficar Ativo na vitrine para os outros interessados.');">
                                                            <i class="bi bi-arrow-counterclockwise me-1"></i> Desfazer Reserva
                                                        </a>
                                                        <a href="/Anuncio/ConcluirDoacao/@Model.Id" class="btn btn-sm btn-success w-50"
                                                           onclick="return confirm('Tem certeza que deseja CONFIRMAR o pedido reserva? O anúncio será concluído nesta etapa.');">
                                                            <i class="bi bi-box-seam-fill me-1"></i> Doação Realizada!
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else if (interesse.Status == Daki.Dominio.Enums.StatusInteresse.Recusada)
                                        {
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2">
                                                Pedido Recusado
                                            </span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
