@model IEnumerable<Daki.Dominio.Entidades.Anuncio>

@{
    ViewData["Title"] = "Meus Anúncios - Daki";
}

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color: #FF7F50;">Meus Anúncios</h2>
        <a href="/Anuncio/Criar" class="btn text-white" style="background-color: #FF7F50;">
            <i class="bi bi-plus-lg me-1"></i> Nova Doação
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-lg overflow-hidden">
        @if (!Model.Any())
        {
            <div class="card-body text-center py-5">
                <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
                <h5 class="mt-3 text-secondary">Você ainda não publicou nenhuma doação.</h5>
                <p class="text-muted">Que tal começar a fazer a diferença hoje mesmo?</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th scope="col" class="ps-4">Item</th>
                            <th scope="col">Categoria</th>
                            <th scope="col">Status</th>
                            <th scope="col">Interessados</th>
                            <th scope="col" class="text-end pe-4">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var anuncio in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @{
                                            var imagemCapa = anuncio.Imagens?.FirstOrDefault(i => i.Principal)?.UrlImagem
                                                             ?? "https://placehold.co/100x100/f8f9fa/ff7f50?text=Sem+Foto";
                                        }
                                        <img src="@imagemCapa" alt="Capa" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                                        <div class="ms-3">
                                            <h6 class="mb-0 fw-bold text-dark">@anuncio.Titulo</h6>
                                            <small class="text-muted">Publicado em @anuncio.DataCriacao.ToString("dd/MM/yyyy")</small>
                                            <small class="text-muted ms-2"><i class="bi bi-eye"></i> @(anuncio.Visualizacoes?.Count ?? 0) views</small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge bg-light text-secondary border">@anuncio.Categoria</span>
                                </td>

                                <td>
                                    @if (anuncio.Status == Daki.Dominio.Enums.Status.Ativo)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">@anuncio.Status</span>
                                    }
                                </td>

                                <td>
                                    <span class="fw-bold" style="color: #FF7F50;">@(anuncio.Interesses?.Count ?? 0)</span> <small class="text-muted">pedidos</small>
                                </td>

                                <td class="text-end pe-4">
                                    @if (anuncio.Status == Daki.Dominio.Enums.Status.Encerrado)
                                    {
                                        <span class="badge bg-danger p-2" title="Este anúncio foi removido por violar as regras da plataforma.">
                                            <i class="bi bi-exclamation-octagon-fill me-1"></i> Removido pela Moderação
                                        </span>
                                    }
                                    else
                                    {
                                        <a href="/Anuncio/Detalhes/@anuncio.Id" class="btn btn-sm btn-outline-secondary me-2" title="Ver como os outros veem">
                                            <i class="bi bi-eye-fill me-1"></i> Ver
                                        </a>
                                        <a href="/Anuncio/Gerenciar/@anuncio.Id" class="btn btn-sm text-white" style="background-color: #FF7F50;" title="Gerenciar Pedidos e Editar">
                                            Gerenciar
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>