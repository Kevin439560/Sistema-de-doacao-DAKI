@model Daki.Web.Models.AnuncioCriarViewModel
@using Daki.Dominio.Enums

@{
    ViewData["Title"] = "Publicar Doação - Daki";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-lg">
                <div class="card-header bg-white border-0 pt-4 pb-0 text-center">
                    <h2 class="fw-bold" style="color: #FF7F50;">O que você deseja doar?</h2>
                    <p class="text-muted">Preencha os detalhes do item e o local de retirada.</p>
                </div>

                <div class="card-body p-5 pt-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3 text-center"></div>

                    <form asp-controller="Anuncio" asp-action="Criar" method="post" enctype="multipart/form-data">

                        <h5 class="mb-3 border-bottom pb-2 text-secondary">Detalhes do Item</h5>

                        <div class="row g-3 mb-4">
                            <div class="col-md-8">
                                <div class="form-floating">
                                    <input asp-for="Titulo" class="form-control" placeholder="Título" />
                                    <label asp-for="Titulo">Título (ex: Sofá de 3 lugares)</label>
                                    <span asp-validation-for="Titulo" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <select asp-for="Categoria" class="form-select" asp-items="Html.GetEnumSelectList<Categoria>()">
                                        <option value="">Selecione...</option>
                                    </select>
                                    <label asp-for="Categoria">Categoria</label>
                                    <span asp-validation-for="Categoria" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="Descricao" class="form-control" placeholder="Descrição" style="height: 100px"></textarea>
                                    <label asp-for="Descricao">Descrição detalhada (estado de conservação, defeitos, etc.)</label>
                                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="row g-3 mb-4 mt-1">
                                <div class="col-12">
                                    <label asp-for="Imagens" class="form-label text-secondary fw-bold">Fotos do Item</label>
                                    <input asp-for="Imagens" type="file" class="form-control form-control-lg" accept="image/jpeg, image/png" multiple />
                                    <span asp-validation-for="Imagens" class="text-danger small"></span>
                                    <div class="form-text">Envie fotos nítidas (apenas JPG ou PNG). A primeira foto selecionada será a capa do anúncio.</div>
                                </div>
                            </div>
                        </div>

                        <h5 class="mb-3 border-bottom pb-2 text-secondary">Local de Retirada</h5>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input asp-for="CEP" class="form-control" placeholder="CEP" />
                                    <label asp-for="CEP">CEP</label>
                                    <span asp-validation-for="CEP" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="form-floating">
                                    <input asp-for="Rua" class="form-control" placeholder="Rua" />
                                    <label asp-for="Rua">Rua</label>
                                    <span asp-validation-for="Rua" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input asp-for="Numero" class="form-control" placeholder="Número" />
                                    <label asp-for="Numero">Número</label>
                                    <span asp-validation-for="Numero" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="form-floating">
                                    <input asp-for="Bairro" class="form-control" placeholder="Bairro" />
                                    <label asp-for="Bairro">Bairro</label>
                                    <span asp-validation-for="Bairro" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-9">
                                <div class="form-floating">
                                    <input asp-for="Cidade" class="form-control" placeholder="Cidade" />
                                    <label asp-for="Cidade">Cidade</label>
                                    <span asp-validation-for="Cidade" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input asp-for="UF" class="form-control" placeholder="UF" maxlength="2" />
                                    <label asp-for="UF">UF</label>
                                    <span asp-validation-for="UF" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-lg text-white" style="background-color: #FF7F50;">
                                <i class="bi bi-megaphone-fill me-2"></i> Publicar Doação
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>