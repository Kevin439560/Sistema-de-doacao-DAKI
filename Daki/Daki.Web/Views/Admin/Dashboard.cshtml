@{
    ViewData["Title"] = "Painel Administrativo";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold" style="color: #FF7F50;">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard Administrativo
            </h2>
            <p class="text-muted">Visão geral do fluxo de doações na plataforma.</p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-0">
                    <h5 class="fw-bold text-secondary">Novos Anúncios (Últimos 7 dias)</h5>
                </div>
                <div class="card-body">
                    <canvas id="graficoAnuncios" height="100"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card shadow-sm border-0 rounded-4 bg-light h-100">
                <div class="card-body d-flex flex-column justify-content-center text-center">
                    <i class="bi bi-shield-check display-1 text-success opacity-50 mb-3"></i>
                    <h4 class="fw-bold">Ambiente Seguro</h4>
                    <p class="text-muted small">Você está autenticado com privilégios de moderação. Todas as ações realizadas aqui são auditadas.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // Recebendo o JSON que o nosso Controller C# gerou
        const labels = @Html.Raw(ViewBag.Labels);
        const data = @Html.Raw(ViewBag.Valores);

        // Desenhando o Gráfico
        const ctx = document.getElementById('graficoAnuncios').getContext('2d');
        new Chart(ctx, {
        type: 'bar', // Tipo barra
        data: {
        labels: labels,
        datasets: [{
        label: 'Anúncios Criados',
        data: data,
        backgroundColor: '#FF7F50', // A cor laranja do seu tema
        borderRadius: 6 // Bordas arredondadas nas barras
        }]
        },
        options: {
        responsive: true,
        plugins: {
        legend: {
        display: false // Esconde a legenda para um visual mais limpo
        }
        },
        scales: {
        y: {
        beginAtZero: true,
        ticks: {
        stepSize: 1 // Impede que o gráfico mostre "1.5 anúncios"
        }
        }
        }
        }
        });
    </script>
}